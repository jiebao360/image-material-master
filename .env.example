# 图片素材生成大师 - 环境变量配置示例
# 复制此文件为 .env 并填入你的 API 密钥

# ============= 火山引擎即梦 AI =============
JIMENG_API_KEY="your_jimeng_api_key_here"
VOLC_ACCESS_KEY="your_volc_access_key_here"
VOLC_SECRET_KEY="your_volc_secret_key_here"
JIMENG_ENDPOINT="https://api.volcengine.com"

# ============= Google Nano Banana Pro =============
GEMINI_API_KEY="your_gemini_api_key_here"

# ============= 飞书 API (自动归档) =============
FEISHU_APP_ID="your_feishu_app_id_here"
FEISHU_APP_SECRET="your_feishu_app_secret_here"

# ============= 可选配置 =============
# 默认输出目录
OUTPUT_DIR="./output"

# 默认分辨率
DEFAULT_RESOLUTION="2K"

# 默认引擎 (jimeng|nano|seedance|auto)
DEFAULT_ENGINE="auto"

# 日志级别 (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL="INFO"
